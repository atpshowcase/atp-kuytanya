# Shared environment template.
# Use .env.development.example, .env.staging.example, or .env.production.example
# as the starting point for each deployment environment.
APP_ENV=development

POSTGRES_USER=kuytanya_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=kuytanya_db

DATABASE_URL=postgres://kuytanya_user:change-me@db:5432/kuytanya_db?sslmode=disable
WA_DB_URL=postgres://kuytanya_user:change-me@db:5432/kuytanya_db?sslmode=disable

JWT_SECRET=change-me-use-at-least-32-random-characters

BACKEND_PORT=8080
FRONTEND_PORT=3000
PORT=8080

FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
