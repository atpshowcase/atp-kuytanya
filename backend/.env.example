# Server
PORT=8080

# PostgreSQL (adjust to your local setup)
DATABASE_URL=host=localhost user=postgres password=yourpassword dbname=atp_chatbot port=5432 sslmode=disable

# WhatsApp / Meta Cloud API
# Get these from https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_meta_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here

# Custom token you create — must match what you set in Meta webhook config
WHATSAPP_VERIFY_TOKEN=my_verify_token
