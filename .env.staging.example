APP_ENV=staging

POSTGRES_USER=kuytanya_staging_user
POSTGRES_PASSWORD=replace-with-staging-password
POSTGRES_DB=kuytanya_staging

DATABASE_URL=postgres://kuytanya_staging_user:replace-with-staging-password@db:5432/kuytanya_staging?sslmode=disable
WA_DB_URL=postgres://kuytanya_staging_user:replace-with-staging-password@db:5432/kuytanya_staging?sslmode=disable

JWT_SECRET=replace-with-staging-random-secret

BACKEND_PORT=8080
FRONTEND_PORT=3000
PORT=8080

FRONTEND_URL=https://staging.example.com
NEXT_PUBLIC_API_URL=https://staging-api.example.com
CORS_ALLOWED_ORIGINS=https://staging.example.com
COOKIE_SECURE=true
